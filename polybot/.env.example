# ============================================================
# PolyBot Production — environment configuration
# DRY_RUN is the default. Read README.md "Going live" first.
# ============================================================

# --- Wallet (NEVER commit this file with real values) ---
# Use a DEDICATED wallet funded with only the trading bankroll.
PRIVATE_KEY=
SAFE_ADDRESS=

# --- Exchange ---
CLOB_HOST=https://clob.polymarket.com

# --- Safety (do not change casually) ---
DRY_RUN=true
# To go live you must ALSO set: LIVE_TRADING_ACK=I_UNDERSTAND_THE_RISKS
LIVE_TRADING_ACK=
KILL_SWITCH_FILE=KILL_SWITCH

# --- Strategy ---
MIN_EDGE=0.01
MIN_PROB=0.55
FEE_RATE_BPS=200
PROB_SHRINKAGE=0.6
# Skip directional entries on books wider than this (adverse selection)
MAX_SPREAD=0.06
# Directional needs elapsed time in the window and a warmed-up vol estimate
DIR_MIN_ELAPSED_S=60
VOL_MIN_SAMPLES=30

# --- Sizing ---
BANKROLL=100
KELLY_MULTIPLIER=0.25
MIN_BET=1
MAX_BET=2
MAX_BANKROLL_FRACTION=0.05

# --- Circuit breakers / capital protection ---
# The BINDING daily limit: worst-case loss per UTC day as a fraction of
# bankroll. Realized loss + worst-case of open positions never exceeds it.
# Hard-capped at 0.05 in code; default 0.01 (1%).
MAX_DAILY_LOSS_PCT=0.01
# Absolute backstop in USDC; the tighter of the two applies.
MAX_DAILY_LOSS=5
# Halt when equity drops this fraction below its high-water mark.
MAX_DRAWDOWN_PCT=0.05
# Optional: stop trading for the day after reaching +X% (0 = disabled).
DAILY_PROFIT_LOCK_PCT=0
MAX_CONSECUTIVE_LOSSES=5
MAX_OPEN_EXPOSURE=10

# --- Market timing ---
ENTRY_MIN_REMAINING_S=20
SETTLE_GRACE_S=15
POLL_INTERVAL_S=1.0

# --- Notifications (alerts only; control stays in the supervisor bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Ops ---
DB_PATH=polybot.sqlite3
